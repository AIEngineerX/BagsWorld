# Path to Android SDK build tools (contains aapt2)
# Windows example: C:\Users\<user>\AppData\Local\Android\Sdk\build-tools\34.0.0
# Mac example: ~/Library/Android/sdk/build-tools/34.0.0
# Linux example: ~/Android/Sdk/build-tools/34.0.0
ANDROID_TOOLS=

# Path to your Solana keypair file
# Generate with: solana-keygen new --outfile publishing/keypair.json
KEYPAIR_PATH=./keypair.json

# Solana RPC URL (mainnet-beta for real submission, devnet for testing)
# Use your Helius RPC for reliability
RPC_URL=https://api.mainnet-beta.solana.com
